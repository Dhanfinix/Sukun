<?xml version="1.0" encoding="utf-8"?>
<!--
    Sukun COMPACT notification view (collapsed state) — RemoteViews safe.
    Simple one-liner: "Phone silenced for [Prayer]" + chronometer on the right.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:minHeight="48dp"
    android:paddingStart="2dp"
    android:paddingEnd="4dp">

    <!-- Left: Title + bold prayer name -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/notif_title"
            android:textAppearance="@style/TextAppearance.Compat.Notification.Title"
            android:layout_marginEnd="4dp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/notification_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fajr"
            android:textAppearance="@style/TextAppearance.Compat.Notification.Title"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Right: Countdown chronometer -->
    <Chronometer
        android:id="@+id/notification_chronometer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:countDown="true"
        android:textAppearance="@style/TextAppearance.Compat.Notification.Title"
        android:textStyle="bold"
        android:fontFamily="monospace" />

</LinearLayout>