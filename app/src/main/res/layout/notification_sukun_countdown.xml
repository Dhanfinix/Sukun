<?xml version="1.0" encoding="utf-8"?>
<!--
    Sukun notification custom view — must be RemoteViews safe.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFF5ED"
    android:padding="16dp">

    <!-- App Icon & Name Header -->
    <LinearLayout
        android:id="@+id/notification_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">
        
        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_notification"
            android:tint="#726158" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="@string/app_name"
            android:textColor="#726158"
            android:textSize="12sp" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" • now"
            android:textColor="#726158"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/notification_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/notification_header"
        android:orientation="horizontal">

        <!-- Left side: Title and Type -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/silence_active"
                android:textColor="#2E231F"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/notification_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Fajr"
                android:textColor="#5C4D44"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Right side: Chronometer -->
        <Chronometer
            android:id="@+id/notification_chronometer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:countDown="true"
            android:textColor="#3D291F"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- Stop Button -->
    <TextView
        android:id="@+id/notification_action_stop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/notification_content"
        android:layout_marginTop="16dp"
        android:text="@string/stop_silence"
        android:textColor="#D32F2F"
        android:textSize="14sp"
        android:textStyle="bold"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:paddingEnd="16dp" />

</RelativeLayout>
